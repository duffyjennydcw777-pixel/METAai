# METAai — Environment Variables
# Скопировать в .env и заполнить реальными значениями
# НИКОГДА не коммитить .env в Git!

# === App ===
APP_NAME=METAai
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# === Database ===
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/metaai

# === Telegram ===
# TELEGRAM_BOT_TOKEN=
# ADMIN_CHAT_ID=

# === AI Agents (OpenRouter) ===
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модели агентов (можно менять)
AGENT_MODEL_ARCHITECT=anthropic/claude-sonnet-4-20250514
AGENT_MODEL_REVIEW=anthropic/claude-3-5-haiku-20241022
AGENT_MODEL_SECURITY=anthropic/claude-sonnet-4-20250514
AGENT_MODEL_TEST=openai/gpt-4o-mini
AGENT_MODEL_PREFLIGHT=google/gemini-2.0-flash-001

# === API Keys ===
# Добавлять по мере необходимости
