# METAai — .gitignore

# Environment
.env
.env.production
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Testing
.coverage
htmlcov/
.pytest_cache/

# Node (если frontend)
node_modules/
.next/
out/

# Temp
*.tmp
*.bak
scratch/

# Generated PDFs & Office docs (не хранить в git)
*.pdf
*.docx
*.odt

# One-off data files
*.json
!package.json
!tsconfig.json
session_text.txt
odt_content.txt
omi_content.txt
satori_report.html

# Agent reports (генерируются автоматически)
agents/reports/

# Legacy one-off scripts (не core)
make_*.py
read_*.py
extract_*.py
server_audit.py
query_users.py
audit.sh
ssh_tunnel_postgres.bat
test_pg.py

