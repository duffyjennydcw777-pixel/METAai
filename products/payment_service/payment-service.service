[Unit]
Description=Solo CTO OS Payment Service v2 (CryptoCloud + Auto-Delivery)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/payment_service
ExecStart=/root/payment_service/venv/bin/python3 main.py
Restart=always
RestartSec=5
EnvironmentFile=/root/payment_service/.env

[Install]
WantedBy=multi-user.target
